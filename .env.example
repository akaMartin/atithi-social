# ============================================================
#  Atithi Social – Friendica instance configuration
#
#  HOW TO USE:
#    cp .env.example .env
#    # Edit .env and fill in every value marked CHANGE_ME
#    # The .env file is gitignored and must never be committed.
#
#  GENERATING SECRETS:
#    openssl rand -base64 32   # strong random password
# ============================================================
 
 
# ─── MariaDB ────────────────────────────────────────────────
# Root password – only used by the MariaDB container internally.
# Never exposed to Friendica; use a strong random value.
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_root_password
 
# Application database name (safe to leave as-is)
MYSQL_DATABASE=friendica
 
# Application database user (safe to leave as-is)
MYSQL_USER=friendica
 
# Application database password – must be strong and unique
MYSQL_PASSWORD=CHANGE_ME_strong_db_password
 
 
# ─── Redis ──────────────────────────────────────────────────
# Redis auth password – required; use a strong random value
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
 
 
# ─── Friendica instance ─────────────────────────────────────
# Full public URL of the instance – must match the SSL certificate.
# Changing this after the first run breaks federation; set it correctly now.
FRIENDICA_URL=https://atithi.social
 
# Admin contact email (receives system notifications)
FRIENDICA_ADMIN_MAIL=admin@atithi.social
 
# Display name shown in the UI and in federation metadata
FRIENDICA_SITENAME=Atithi Social
 
# IANA timezone string  (e.g. UTC, Asia/Kolkata, America/New_York)
FRIENDICA_TZ=UTC
 
# ISO 639-1 two-letter default language code
FRIENDICA_LANG=en
 
 
# ─── SMTP outbound mail (optional) ──────────────────────────
# Leave SMTP blank to disable outbound email entirely.
# Friendica will still function but cannot send notifications or confirmations.
 
# Hostname or IP of your SMTP relay
SMTP=
 
# SMTP port: 587 (STARTTLS, recommended), 465 (SSL), or 25 (unencrypted)
SMTP_PORT=587
 
# EHLO/HELO domain – usually your instance domain
SMTP_DOMAIN=atithi.social
 
# Envelope-From address for outbound mail
SMTP_FROM=noreply@atithi.social
 
# SMTP authentication credentials (leave blank for unauthenticated relay)
SMTP_USERNAME=
SMTP_PASSWORD=
 
# Authentication mechanism: LOGIN, PLAIN, CRAM-MD5
SMTP_AUTH=LOGIN
 
# Encryption: tls (STARTTLS) or ssl (implicit TLS)
SMTP_SECURE=tls